{
  "framework": "nextjs",
  "buildCommand": "next build",
  "devCommand": "next dev",
  "installCommand": "npm install",
  "regions": ["sin1"],
  "crons": [
    {
      "path": "/api/cron/abandoned-cart",
      "schedule": "0 8 * * *"
    },
    {
      "path": "/api/cron/expire-subscriptions",
      "schedule": "0 2 * * *"
    },
    {
      "path": "/api/email/automations/process",
      "schedule": "0 1 * * *"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Robots-Tag",
          "value": "all"
        }
      ]
    }
  ]
}
